{
  "name": "my-ai-coding-console",
  "version": "1.0.0",
  "private": true,
  "description": "AI Coding Console - Real-time AI agent activity visualizer",
  "author": {
    "name": "AI Coding Console",
    "email": "dev@ai-coding-console.app"
  },
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "main": "electron/main.cjs",
  "scripts": {
    "app": "electron .",
    "app:build": "npm run build:shared && npm run build -w frontend && electron .",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "build:shared": "npm run build -w shared",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.ai-coding-console.app",
    "productName": "AI Coding Console",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "backend/dist/**/*",
      "backend/package.json",
      "frontend/package.json",
      "shared/dist/**/*",
      "shared/package.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend/.next",
        "to": "app/frontend/.next",
        "filter": ["**/*"]
      },
      {
        "from": "node_modules",
        "to": "app/node_modules",
        "filter": [
          "**/*",
          "!**/*.map",
          "!**/*.ts",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/docs/**",
          "!**/example/**",
          "!**/examples/**",
          "!**/*.md",
          "!**/CHANGELOG*",
          "!**/LICENSE*",
          "!**/.eslint*",
          "!**/.prettier*"
        ]
      }
    ],
    "asar": false,
    "mac": {
      "target": ["dmg"],
      "icon": "electron/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "electron/icon.png",
      "category": "Development",
      "desktop": {
        "entry": {
          "Name": "AI Coding Console",
          "Comment": "AI Coding Console",
          "Terminal": "false"
        }
      }
    },
    "win": {
      "target": ["nsis"],
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "AI 코딩 콘솔"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.0"
  }
}
